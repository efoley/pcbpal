{
  "name": "pcbpal",
  "version": "0.1.0",
  "description": "CLI companion tool for PCB design \u2014 BOM management, component search, production config",
  "type": "module",
  "bin": {
    "pcbpal": "./src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "test": "bun test",
    "evals": "bun evals/src/run.ts",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@iarna/toml": "^2.2.5",
    "circuit-json-to-kicad": "^0.0.87",
    "circuit-to-svg": "^0.0.338",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1",
    "tscircuit": "^0.0.1546",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@types/bun": "^1.2.4",
    "typescript": "^5.7.3"
  }
}
